# Auron E-Commerce Platform - Environment Variables
# Copy this file to .env and fill in the values

# ============================================================
# JWT CONFIGURATION
# ============================================================
# Shared HMAC secret — must be identical in user-service and api-gateway
# Generate with: openssl rand -hex 32
JWT_SECRET=your-strong-secret-min-32-chars-here
# Optional: separate secret for refresh tokens. Falls back to JWT_SECRET if unset.
JWT_REFRESH_SECRET=your-refresh-token-secret-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ============================================================
# KAFKA
# ============================================================
KAFKA_BROKERS=kafka:9092

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# STRIPE
# ============================================================
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================
# EMAIL (SMTP)
# ============================================================
SMTP_HOST=smtp-host
SMTP_PORT=587
SMTP_FROM=noreply@auron.shop
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# ============================================================
# TWILIO (Optional - for SMS)
# ============================================================
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ============================================================
# FRONTEND
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ============================================================
# DATABASE
# ============================================================
POSTGRES_USER=auron
POSTGRES_PASSWORD=auron_pass
