# User Service
# Copy this file to .env and adjust values for your environment.

# HTTP server port
PORT=8081

# PostgreSQL connection for user-service
DATABASE_URL=postgres://auron:auron_pass@localhost:5432/users_db?sslmode=disable

# Redis connection for user-service cache
REDIS_URL=redis://localhost:6379/0

# Kafka brokers for event publishing (comma-separated)
KAFKA_BROKERS=localhost:9092

# JWT signing secret for access tokens (required)
JWT_SECRET=change-me-access-secret

# JWT signing secret for refresh tokens (optional fallback to JWT_SECRET if empty)
JWT_REFRESH_SECRET=change-me-refresh-secret
