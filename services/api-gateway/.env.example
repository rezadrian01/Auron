# API Gateway
# Copy to .env and adjust values.

PORT=8080

# Backward-compatible explicit upstream variables
USER_SERVICE_URL=http://localhost:8081
PRODUCT_SERVICE_URL=http://localhost:8082
ORDER_SERVICE_URL=http://localhost:8083
PAYMENT_SERVICE_URL=http://localhost:8084
INVENTORY_SERVICE_URL=http://localhost:8085

# Preferred generic upstream mapping for easy extension
# Format: service=url,service2=url2
# SERVICE_URLS=user=http://localhost:8081,product=http://localhost:8082
SERVICE_URLS=

# Optional per-service override/addition (highest precedence)
# Example for future notification-service:
# SERVICE_URL_NOTIFICATION=http://localhost:8086

REDIS_URL=redis://localhost:6379/0
JWT_PUBLIC_KEY=/run/secrets/jwt-public-key
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
